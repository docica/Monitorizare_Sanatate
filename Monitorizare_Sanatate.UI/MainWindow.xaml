<Window x:Class="Monitorizare_Sanatate.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Monitorizare_Sanatate.UI"
        mc:Ignorable="d"
        Title="Monitorizare Sanatate" Height="750" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0"
                    Background="#F0F8FF"
                    Margin="0,0,10,0">
            <TextBlock Text="MENIU" 
                       HorizontalAlignment="Center" 
                       FontWeight="Bold"
                       Margin="10"/>
            <Button x:Name="btnMeniuAdmin"
                    Content="Administrare pacienti"
                    Height="40"
                    Margin="5"
                    Click="btnMeniu_Click"/>
            <Button x:Name="btnMeniuCauta"
                    Content="Cauta"
                    Height="40"
                    Margin="5"
                    Click="btnMeniu_Click"/>
        </StackPanel>
        <Grid Grid.Column="1">
            <Border x:Name="pnlAdministrare"
                    Visibility="Visible"
                    BorderBrush="#EAF6FB"
                    BorderThickness="15"
                    Margin="12">
                

                <StackPanel Margin="20">
                    <TextBlock Text="Date pacient" 
                               FontSize="24"
                               FontWeight="Bold" 
                               Foreground="Navy"
                               HorizontalAlignment="Center" 
                               Margin="0, 0, 0, 20"/>


                    <GroupBox Header="Adăugare Pacient" Margin="0,0,0,20" Padding="10">
                        <StackPanel>
                            <Grid HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>

                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>

                                <Label x:Name="lblNume" Content="Nume:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtNume" Grid.Row="0" Grid.Column="1" Margin="5" Height="25"/>

                                <Label x:Name="lblPrenume" Content="Prenume:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtPrenume" Grid.Row="1" Grid.Column="1" Margin="5" Height="25"/>

                                <Label x:Name="lblTelefon" Content="Telefon:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtTelefon" Grid.Row="2" Grid.Column="1" Margin="5" Height="25"/>

                                <Label x:Name="lblEmail" Content="Email:" Grid.Row="3" Grid.Column="0" Margin="5"/>
                                <TextBox x:Name="txtEmail" Grid.Row="3" Grid.Column="1" Margin="5" Height="25"/>

                                <Label x:Name="lblDataNasterii" Content="Data Nașterii:" Grid.Row="4" Grid.Column="0" Margin="5"/>
                                <TextBox x:Name="txtDataNasterii" Grid.Row="4" Grid.Column="1" Margin="5" Height="25"/>

                                <StackPanel Grid.Row="5" 
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Margin="5">
                                    <Label Content="Gen: "
                                           FontWeight="Bold"
                                           Padding="0"
                                           Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="rbNespecificat"
                                                     Content="Nespecificat"
                                                     IsChecked="True"
                                                     Margin="0,0,20,0"/>
                                        <RadioButton x:Name="rbMasculin"
                                                     Content="Masculin"
                                                     Margin="0,0,20,0"/>
                                        <RadioButton x:Name="rbFeminin"
                                                     Content="Feminin"
                                                     Margin="0,0,20,0"/>
                                        
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="6"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Margin="5">
                                    <Label Content="Simptome glicemie: "
                                           FontWeight="Bold"
                                           Padding="0"
                                           Margin="0,0,0,6">
                                    </Label>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="cbAmeteala"
                                                  Content="Ameteala"
                                                  Margin="0,0,20,0"
                                                  Checked="Simptome_CheckedChanged"
                                                  Unchecked="Simptome_CheckedChanged"/>
                                        <CheckBox x:Name="cbTremur"
                                                  Content="Tremur"
                                                  Margin="0,0,20,0"
                                                  Checked="Simptome_CheckedChanged"
                                                  Unchecked="Simptome_CheckedChanged"/>
                                        <CheckBox x:Name="cbTranspiratie"
                                                     Content="Transpiratie"
                                                     Margin="0,0,20,0"
                                                     Checked="Simptome_CheckedChanged"
                                                     Unchecked="Simptome_CheckedChanged"/>
                                        
                                    </StackPanel>
                                           
                                </StackPanel>

                                <StackPanel Grid.Row="7"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Margin="5">
                                    <Label Content="Simptome tensiune: "
                                           FontWeight="Bold"
                                           Padding="0"
                                           Margin="0,0,0,6">
                                    </Label>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="cbDurereDeCap"
                                                  Content="Durere de cap"
                                                  Margin="0,0,20,0"
                                                  Checked="Simptome_CheckedChanged"
                                                  Unchecked="Simptome_CheckedChanged"/>
                                        
                                        <CheckBox x:Name="cbPalpitatii"
                                                  Content="Palpitatii"
                                                  Margin="0,0,20,0"
                                                  Checked="Simptome_CheckedChanged"
                                                  Unchecked="Simptome_CheckedChanged"/>
                                        <CheckBox x:Name="cbOboseala"
                                                  Content="Oboseala"
                                                  Margin="0,0,20,0"
                                                  Checked="Simptome_CheckedChanged"
                                                  Unchecked="Simptome_CheckedChanged"/>
                                    </StackPanel>

                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Grid.Row="8" Grid.Column="1" HorizontalAlignment="Right" Margin="5">
                                    <Button x:Name="btnAdauga" Content="Adaugă" Width="80" Margin="0,0,10,0" Click="btnAdauga_Click"/>
                                    <Button x:Name="btnReset" Content="Reset" Width="80" Click="btnReset_Click"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="lblMesajEroare" Foreground="Red" HorizontalAlignment="Center" FontWeight="Bold" Visibility="Collapsed" Margin="5"/>
                            <Label x:Name="lblNrPacienti" Margin="5,15,5,0" FontWeight="Bold"/>
                            <Label x:Name="lblPacienti" Margin="5" VerticalAlignment="Top"/>
                        </StackPanel>
                    </GroupBox>


                </StackPanel>
            </Border>
            <Border x:Name="pnlCautare" Visibility="Collapsed" BorderBrush="#EAF6FB" BorderThickness="15" Margin="12">
                <StackPanel Margin="20">
                    <TextBlock Text="Căutare Pacient" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Label Content="Caută după nume: " VerticalAlignment="Center"/>
                        <TextBox x:Name="txtCautareNume" Width="200" Height="25" Margin="5"/>
                        <Button x:Name="btnExecutaCautare" Content="Caută" Width="80" Click="btnExecutaCautare_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="lblRezultatCautare" TextWrapping="Wrap" FontStyle="Italic"/>
                </StackPanel>
            </Border>



        </Grid>

            
        
    </Grid>
</Window>