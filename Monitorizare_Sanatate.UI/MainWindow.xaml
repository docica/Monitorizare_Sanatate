<Window x:Class="Monitorizare_Sanatate.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Monitorizare_Sanatate.UI"
        mc:Ignorable="d"
        Title="Monitorizare Sanatate" Height="500" Width="800">
    <Grid>
        <Border BorderBrush="#EAF6FB" BorderThickness="15" Margin="12">
            <StackPanel Margin="20">
                <TextBlock Text="Date pacient" FontSize="24" FontWeight="Bold" Foreground="Navy"
                           HorizontalAlignment="Center" Margin="0, 0, 0, 20"/>

                <ListBox x:Name="ListBoxPacienti" Height="350" Margin="5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Id:" FontSize="18" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding IdPacient}" FontSize="18" FontStyle="Italic" Margin="5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Nume:" FontSize="18" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Nume}" FontSize="18" FontStyle="Italic" Margin="5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Prenume: " FontSize="18" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Prenume}" FontSize="18" FontStyle="Italic" Margin="5"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Data Nasterii: " FontSize="18" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DataNasterii}" FontSize="18" FontStyle="Italic" Margin="5"/>

                                <TextBlock Grid.Row="4" Grid.Column="0"  Text="Email: " FontSize="18" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Email}" FontSize="18" FontStyle="Italic" Margin="5"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Telefon: " FontSize="18" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Telefon}" FontSize="18" FontStyle="Italic" Margin="5"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
    </Grid>
</Window>